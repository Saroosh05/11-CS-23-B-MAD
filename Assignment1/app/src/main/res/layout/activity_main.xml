<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Heading -->
        <TextView
            android:id="@+id/heading"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Quiz App"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Subheading -->
        <TextView
            android:id="@+id/subheading"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Choose the correct option for each question"
            android:textSize="16sp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/heading"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />

        <!-- Question 1 -->
        <TextView
            android:id="@+id/question1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="1. What is the capital of France?"
            android:textSize="16sp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/subheading"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <RadioGroup
            android:id="@+id/options1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/question1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <RadioButton android:id="@+id/q1_option1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Berlin"/>
            <RadioButton android:id="@+id/q1_option2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Madrid"/>
            <RadioButton android:id="@+id/q1_option3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Paris"/>
            <RadioButton android:id="@+id/q1_option4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rome"/>
        </RadioGroup>

        <!-- Question 2 -->
        <TextView
            android:id="@+id/question2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="2. Which planet is known as the Red Planet?"
            android:textSize="16sp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/options1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <RadioGroup
            android:id="@+id/options2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/question2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <RadioButton android:id="@+id/q2_option1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Earth"/>
            <RadioButton android:id="@+id/q2_option2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mars"/>
            <RadioButton android:id="@+id/q2_option3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jupiter"/>
            <RadioButton android:id="@+id/q2_option4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Venus"/>
        </RadioGroup>

        <!-- Question 3 -->
        <TextView
            android:id="@+id/question3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="3. Who wrote 'Romeo and Juliet'?"
            android:textSize="16sp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/options2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <RadioGroup
            android:id="@+id/options3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/question3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <RadioButton android:id="@+id/q3_option1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Charles Dickens"/>
            <RadioButton android:id="@+id/q3_option2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="William Shakespeare"/>
            <RadioButton android:id="@+id/q3_option3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Leo Tolstoy"/>
            <RadioButton android:id="@+id/q3_option4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mark Twain"/>
        </RadioGroup>

        <!-- Question 4 -->
        <TextView
            android:id="@+id/question4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="4. Which gas do plants absorb from the atmosphere?"
            android:textSize="16sp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/options3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <RadioGroup
            android:id="@+id/options4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/question4"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <RadioButton android:id="@+id/q4_option1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Oxygen"/>
            <RadioButton android:id="@+id/q4_option2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Carbon Dioxide"/>
            <RadioButton android:id="@+id/q4_option3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nitrogen"/>
            <RadioButton android:id="@+id/q4_option4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hydrogen"/>
        </RadioGroup>

        <!-- Question 5 -->
        <TextView
            android:id="@+id/question5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="5. What is 5 + 7?"
            android:textSize="16sp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/options4"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <RadioGroup
            android:id="@+id/options5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/question5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <RadioButton android:id="@+id/q5_option1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10"/>
            <RadioButton android:id="@+id/q5_option2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="11"/>
            <RadioButton android:id="@+id/q5_option3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12"/>
            <RadioButton android:id="@+id/q5_option4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="13"/>
        </RadioGroup>

        <!-- Submit Button -->
        <Button
            android:id="@+id/submitButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Submit"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/options5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>